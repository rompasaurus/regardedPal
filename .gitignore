website/venv/
website/site/

# Pico SDK build artifacts (all firmware projects)
dev-setup/*/build/

# picowota bootloader build
picowota/build/

# Generated quote data (DevTool generates at build time)
dev-setup/*/quotes.h

# Waveshare library symlinks and SDK import (auto-created per setup guide)
dev-setup/*/lib
dev-setup/*/pico_sdk_import.cmake
# Keep hello-world/lib as the shared source (not a symlink)
!dev-setup/hello-world/lib/
!dev-setup/hello-world/pico_sdk_import.cmake

# WiFi credentials — never commit real passwords
dev-setup/*/wifi_config.local.h

# DevTool user settings
.config/dilder-devtool/

# Python
__pycache__/
*.pyc

# VSCode workspace settings (user-specific)
.vscode/
hardware-design/kicad/dilder-breadboard/.history

# KiCad lock files and backups
*.lck
*-backups/
hardware-design/Board Design kicad/.history/
**/.history/

# FreeCAD backup files
*.FCBak

# Raw camera photos (converted to JPEG before committing)
*.heic
