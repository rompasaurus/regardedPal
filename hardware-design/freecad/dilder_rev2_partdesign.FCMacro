"""
Dilder Rev 2 -- TRUE Parametric FreeCAD Model (PartDesign)
==========================================================
Builds all 3 parts using real PartDesign features:
  Sketcher constraints, Pads, Pockets, Fillets, Additive/Subtractive primitives.

Every feature appears in the Model tree. Double-click any sketch to edit
its geometry. Change any value in the Parameters spreadsheet and hit
recompute (Ctrl+Shift+R) -- the entire model updates.

Usage:
  FreeCAD > Macro > Run Macro > select this file
"""

import math
import FreeCAD as App
import Part
import Sketcher

V = App.Vector
ROT0 = App.Rotation()

# =====================================================================
# HELPERS
# =====================================================================

def find_edges(feature, axis=None, z_near=None, z_max=None):
    """Find edge names by orientation or position."""
    results = []
    for i, e in enumerate(feature.Shape.Edges):
        verts = e.Vertexes
        if len(verts) != 2:
            continue
        p1, p2 = verts[0].Point, verts[1].Point
        if axis == "vertical":
            if abs(p1.x - p2.x) < 0.01 and abs(p1.y - p2.y) < 0.01 and abs(p1.z - p2.z) > 0.5:
                results.append(f"Edge{i + 1}")
        elif axis == "horizontal_bottom":
            mid_z = (p1.z + p2.z) / 2
            if abs(p1.z - p2.z) < 0.01 and mid_z < 0.5:
                results.append(f"Edge{i + 1}")
    return results


