"""
Dilder Rev 2 -- Parametric FreeCAD Assembly
============================================
FreeCAD macro that generates the full 3-part enclosure:
  1. Base Plate     (solar pit, USB-C cutout, corner pegs, battery troughs)
  2. AAA Cradle     (battery bays, clip slots, Pico nest, TP4056 indent)
  3. Top Cover      (display window, joystick hole, bullnose shell, M3 bores)

All dimensions live in a FreeCAD Spreadsheet ("Parameters") for GUI editing.
Geometry is rebuilt from scratch each run -- edit the spreadsheet then re-run.

Based on the Rev 2 "extended with joystick" OpenSCAD working model
(04-26/27-2026 design alterations).

Usage:
  FreeCAD -> Macro -> Run Macro -> select this file
  Or: FreeCADCmd this_file.py  (headless)
"""

import FreeCAD as App
import Part
import math

# =====================================================================
# PARAMETERS -- mirrors the OpenSCAD customizer values
# =====================================================================

P = {}  # filled by _init_params(), keyed by spreadsheet alias

